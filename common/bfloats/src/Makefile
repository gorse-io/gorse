MUNIT_DIR = ../../floats/src
VPATH = $(MUNIT_DIR)
MUNIT_SOURCE = $(MUNIT_DIR)/munit.c
COMMON_TEST_SOURCES = bfloats_test.c
COMMON_CFLAGS = -O3 -std=gnu11 -I$(MUNIT_DIR)
LDLIBS = -lm
HOST_ARCH := $(shell uname -m)

AMD64_CC ?= x86_64-linux-gnu-gcc
AMD64_QEMU ?= qemu-x86_64
AMD64_QEMU_FLAGS ?= -cpu max
AMD64_CFLAGS = $(COMMON_CFLAGS) -mavx
AMD64_BUILD_DIR = build/amd64
AMD64_SOURCES = bfloats_avx.c
AMD64_OBJECTS = $(addprefix $(AMD64_BUILD_DIR)/,$(AMD64_SOURCES:.c=.o))
AMD64_DEPENDENCES = $(AMD64_OBJECTS:.o=.d)
AMD64_ASSEMBLIES = $(addprefix $(AMD64_BUILD_DIR)/,$(AMD64_SOURCES:.c=.s))
AMD64_TEST_OBJECTS = $(addprefix $(AMD64_BUILD_DIR)/,$(COMMON_TEST_SOURCES:.c=.o)) $(AMD64_OBJECTS)
AMD64_TEST_DEPENDENCES = $(AMD64_TEST_OBJECTS:.o=.d)
AMD64_EXECUTE = bfloats_test_amd64

ARM64_CC ?= aarch64-linux-gnu-gcc
ARM64_SYSROOT ?=
ARM64_QEMU ?= qemu-aarch64
ARM64_QEMU_FLAGS ?= -cpu max
ARM64_CFLAGS = $(COMMON_CFLAGS)
ARM64_LDFLAGS = -static
ARM64_BUILD_DIR = build/arm64
ARM64_SOURCES = bfloats_neon.c
ARM64_OBJECTS = $(addprefix $(ARM64_BUILD_DIR)/,$(ARM64_SOURCES:.c=.o))
ARM64_DEPENDENCES = $(ARM64_OBJECTS:.o=.d)
ARM64_ASSEMBLIES = $(addprefix $(ARM64_BUILD_DIR)/,$(ARM64_SOURCES:.c=.s))
ARM64_TEST_OBJECTS = $(addprefix $(ARM64_BUILD_DIR)/,$(COMMON_TEST_SOURCES:.c=.o)) $(ARM64_OBJECTS)
ARM64_TEST_DEPENDENCES = $(ARM64_TEST_OBJECTS:.o=.d)
ARM64_EXECUTE = bfloats_test_arm64
ifneq ($(ARM64_SYSROOT),)
ARM64_CFLAGS += --sysroot=$(ARM64_SYSROOT)
ARM64_LDFLAGS += --sysroot=$(ARM64_SYSROOT)
endif

RISCV64_CC ?= riscv64-linux-gnu-gcc
RISCV64_QEMU ?= qemu-riscv64
RISCV64_QEMU_FLAGS ?= -cpu max
RISCV64_CFLAGS = $(COMMON_CFLAGS) -march=rv64gcv -mabi=lp64d
RISCV64_LDFLAGS = -static
RISCV64_BUILD_DIR = build/riscv64
RISCV64_SOURCES = bfloats_rvv.c
RISCV64_OBJECTS = $(addprefix $(RISCV64_BUILD_DIR)/,$(RISCV64_SOURCES:.c=.o))
RISCV64_DEPENDENCES = $(RISCV64_OBJECTS:.o=.d)
RISCV64_ASSEMBLIES = $(addprefix $(RISCV64_BUILD_DIR)/,$(RISCV64_SOURCES:.c=.s))
RISCV64_TEST_OBJECTS = $(addprefix $(RISCV64_BUILD_DIR)/,$(COMMON_TEST_SOURCES:.c=.o)) $(RISCV64_OBJECTS)
RISCV64_TEST_DEPENDENCES = $(RISCV64_TEST_OBJECTS:.o=.d)
RISCV64_EXECUTE = bfloats_test_riscv64

ifeq ($(HOST_ARCH),x86_64)
	HOST_TEST_OBJECTS = $(AMD64_TEST_OBJECTS)
	HOST_DEPENDENCES = $(AMD64_TEST_DEPENDENCES)
	HOST_CFLAGS = $(AMD64_CFLAGS)
	EXECUTE = bfloats_test
else ifeq ($(HOST_ARCH),aarch64)
	HOST_TEST_OBJECTS = $(ARM64_TEST_OBJECTS)
	HOST_DEPENDENCES = $(ARM64_TEST_DEPENDENCES)
	HOST_CFLAGS = $(ARM64_CFLAGS)
	EXECUTE = bfloats_test
else ifeq ($(HOST_ARCH),riscv64)
	HOST_TEST_OBJECTS = $(RISCV64_TEST_OBJECTS)
	HOST_DEPENDENCES = $(RISCV64_TEST_DEPENDENCES)
	HOST_CFLAGS = $(RISCV64_CFLAGS)
	EXECUTE = bfloats_test
endif

.PHONY: test test-amd64 test-arm64 test-riscv64 clean

$(EXECUTE): $(HOST_TEST_OBJECTS)
	$(CC) $(HOST_CFLAGS) $(MUNIT_SOURCE) $(HOST_TEST_OBJECTS) $(LDLIBS) -o $(EXECUTE)

test: $(EXECUTE)
	./$(EXECUTE)

$(AMD64_EXECUTE): $(AMD64_TEST_OBJECTS)
	$(AMD64_CC) $(AMD64_CFLAGS) $(MUNIT_SOURCE) $(AMD64_TEST_OBJECTS) $(LDLIBS) -o $(AMD64_EXECUTE)

test-amd64: $(AMD64_EXECUTE)
	@echo "Running AMD64 tests under qemu (make test runs natively on the host)"
	$(AMD64_QEMU) $(AMD64_QEMU_FLAGS) ./$(AMD64_EXECUTE)

$(ARM64_EXECUTE): $(ARM64_TEST_OBJECTS)
	$(ARM64_CC) $(ARM64_CFLAGS) $(MUNIT_SOURCE) $(ARM64_TEST_OBJECTS) $(ARM64_LDFLAGS) $(LDLIBS) -o $(ARM64_EXECUTE)

test-arm64: $(ARM64_EXECUTE)
	$(ARM64_QEMU) $(ARM64_QEMU_FLAGS) ./$(ARM64_EXECUTE)

$(RISCV64_EXECUTE): $(RISCV64_TEST_OBJECTS)
	$(RISCV64_CC) $(RISCV64_CFLAGS) $(MUNIT_SOURCE) $(RISCV64_TEST_OBJECTS) $(RISCV64_LDFLAGS) $(LDLIBS) -o $(RISCV64_EXECUTE)

test-riscv64: $(RISCV64_EXECUTE)
	$(RISCV64_QEMU) $(RISCV64_QEMU_FLAGS) ./$(RISCV64_EXECUTE)

$(AMD64_BUILD_DIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(AMD64_CC) $(AMD64_CFLAGS) -MMD -MP -c $< -o $@

$(AMD64_BUILD_DIR)/%.s: %.c
	@mkdir -p $(dir $@)
	$(AMD64_CC) $(AMD64_CFLAGS) -S $< -o $@

$(ARM64_BUILD_DIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(ARM64_CC) $(ARM64_CFLAGS) -MMD -MP -c $< -o $@

$(ARM64_BUILD_DIR)/%.s: %.c
	@mkdir -p $(dir $@)
	$(ARM64_CC) $(ARM64_CFLAGS) -S $< -o $@

$(RISCV64_BUILD_DIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(RISCV64_CC) $(RISCV64_CFLAGS) -MMD -MP -c $< -o $@

$(RISCV64_BUILD_DIR)/%.s: %.c
	@mkdir -p $(dir $@)
	$(RISCV64_CC) $(RISCV64_CFLAGS) -S $< -o $@

clean:
	rm -rf $(AMD64_BUILD_DIR) $(ARM64_BUILD_DIR) $(RISCV64_BUILD_DIR) $(EXECUTE) $(AMD64_EXECUTE) $(ARM64_EXECUTE) $(RISCV64_EXECUTE)

-include $(HOST_DEPENDENCES) $(AMD64_DEPENDENCES) $(AMD64_TEST_DEPENDENCES) $(ARM64_DEPENDENCES) $(ARM64_TEST_DEPENDENCES) $(RISCV64_DEPENDENCES) $(RISCV64_TEST_DEPENDENCES)
