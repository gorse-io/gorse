# ---------------------------------------------------------------
# Python LangGraph agent — environment config
# Copy to .env and fill in your values. Never commit .env.
# Port 5002  (Go API: 5001, Gorse: 8088)
# ---------------------------------------------------------------

# --- LLM (Gemini via Google AI Studio) ---
# Only Gemini models support function calling. Gemma is used for text synthesis only.
GOOGLE_API_KEY=your_google_ai_studio_key
GOOGLE_MODEL=gemma-3-12b-it

# --- Agent model tiering ---
# Router: Gemini required for function/tool calling.
# Finalizer: Gemma works here (no tool calls, plain text synthesis).
AGENT_ROUTER_MODEL=gemini-2.5-flash
AGENT_FINAL_MODEL=gemma-3-27b-it
AGENT_MAX_ITERATIONS=8
AGENT_TOKEN_BUDGET=20000

# --- Tavily web search ---
TAVILY_API_KEY=your_tavily_api_key

# --- PostgreSQL (same DB as Go service) ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --- Gorse recommendation engine ---
GORSE_URL=http://localhost:8088
GORSE_API_KEY=
